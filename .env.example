# ─── BEACON — Environment Variables ───
# Copy this file to .env.local and fill in values as needed.
# The platform works without most keys — data sources with missing keys are gracefully skipped.

# ── AI Intelligence Layer (Groq / OpenRouter) ──
# Get free API keys at https://console.groq.com/keys or https://openrouter.ai/keys
# GROQ_API_KEY=
# OPENROUTER_API_KEY=

# ── Data Source API Keys (optional) ──
# FIRMS_API_KEY=                        # NASA FIRMS fire data (https://firms.modaps.eosdis.nasa.gov/api/area/)
# AIS_API_KEY=                          # Maritime vessel tracking (aisstream.io)
# OPENSKY_CLIENT_ID=                    # OpenSky OAuth2 — higher rate limits
# OPENSKY_CLIENT_SECRET=                # OpenSky OAuth2
# N2YO_API_KEY=                         # Satellite tracking (n2yo.com)

# ── RF / P25 Radio Feeds (optional) ──
# OPENMHZ_SYSTEM=                       # OpenMHz system ID (e.g. mcsdr for Monroe County)
# OPENMHZ_API_KEY=                      # OpenMHz API key if required

# ── Redis (optional — enables caching, feed state, health checks) ──
# BEACON_REDIS_URL=                     # Redis URL (e.g. redis://localhost:6379 or rediss://user:pass@host:port)

# ── Scanner Backend (required for RECON features) ──
# SCANNER_URL=http://your-scanner:7700  # Beacon scanner backend URL
# SCANNER_KEY=                          # Scanner authentication key (must match backend BEACON_KEY)

# ── Auth (optional — enables multi-user, prefs, API keys) ──
# AUTH_SECRET=                          # Generate with: openssl rand -base64 32
# AUTH_GOOGLE_ID=                       # Google OAuth client ID
# AUTH_GOOGLE_SECRET=                   # Google OAuth client secret
# AUTH_GITHUB_ID=                       # GitHub OAuth client ID
# AUTH_GITHUB_SECRET=                   # GitHub OAuth client secret

# ── Analytics (optional) ──
# VERCEL_ANALYTICS_ID=                  # Vercel Analytics project ID